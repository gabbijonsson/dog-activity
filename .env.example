# Supabase — client-safe (browser)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase — server-only (never use VITE_ prefix; server functions only)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PW=

# Google Maps — server key for geocoding + driving distance (server functions only)
GOOGLE_MAPS_SERVER_KEY=
# Optional dev fallback when server/browser keys are empty
GOOGLE_MAPS_DEMO_KEY=

# Google Maps — browser key for interactive pin map (HTTP-referrer restricted)
VITE_GOOGLE_MAPS_BROWSER_KEY=
# Optional dev fallback for browser map (same value as demo key is fine locally)
VITE_GOOGLE_MAPS_DEMO_KEY=
